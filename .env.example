# Discord OAuth - get these from https://discord.com/developers/applications
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret

# NextAuth
AUTH_SECRET=run_npx_auth_secret_to_generate
NEXTAUTH_URL=http://localhost:3000

# Turso Database - get these from https://turso.tech
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token

# Admin Discord user IDs (comma-separated). These users get access to /admin.
# Find your ID: Discord Settings > Advanced > Developer Mode, then right-click your name > Copy User ID
ADMIN_USER_IDS=602544892383854594
